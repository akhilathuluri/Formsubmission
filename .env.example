# PostgreSQL connection string
# Active template: transactional pooler (recommended)
DATABASE_URL=postgresql://postgres.gqrfytjqmilakjlcklfo:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=verify-full

# Direct connection
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.gqrfytjqmilakjlcklfo.supabase.co:5432/postgres?sslmode=verify-full

# Session pooler
# DATABASE_URL=postgresql://postgres.gqrfytjqmilakjlcklfo:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=verify-full

# API server port
PORT=8787

# Total shared pool of hours. "1 crore" hours = 10000000
TOTAL_POOL_HOURS=10000000

# SSL controls for Node PostgreSQL client.
# Set DB_SSL_REJECT_UNAUTHORIZED=false only when your network/proxy injects a self-signed cert.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# Schema initialization strategy for API functions.
# true  -> API can auto-create tables/indexes on request path (slower cold starts)
# false -> Fastest request path; initialize schema separately using SQL migration
SCHEMA_AUTO_INIT=false

# Optional frontend override (useful with `npm run dev:client`)
# Example: VITE_API_BASE_URL=https://your-vercel-domain.vercel.app
VITE_API_BASE_URL=
